@page "/rules/{Id:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@using InotifyRelay.Core.Events
@using InotifyRelay.Data.Entities
@inject InotifyRelay.Web.Services.RuleService RuleSvc
@inject InotifyRelay.Web.Services.TargetService TargetSvc
@inject NavigationManager Nav

<PageTitle>Edit rule — inotify-relay</PageTitle>

@if (rule is null)
{
    <p class="ir-muted">Loading…</p>
}
else
{
    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem">
        <h1 style="margin:0">@rule.Name</h1>
        <div>
            <button class="btn btn-primary" @onclick="SaveAsync">Save</button>
            <a class="btn btn-secondary" href="/rules">Back</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(saveError))
    {
        <div class="alert-error" style="margin-top:1rem">@saveError</div>
    }

    <div class="ir-card" style="margin-top:1rem">
        <h2>General</h2>
        <div class="ir-form-grid">
            <div>
                <label>Name</label>
                <input @bind="rule.Name" />
            </div>
            <div>
                <label>Description</label>
                <input @bind="rule.Description" />
            </div>
            <div class="ir-form-row">
                <div>
                    <label>Debounce (ms)</label>
                    <input type="number" min="0" @bind="rule.DebounceMs" />
                </div>
                <div>
                    <label>Stabilization (ms)</label>
                    <input type="number" min="0" @bind="rule.StabilizationMs" />
                </div>
            </div>
            <label style="display:flex;align-items:center;gap:0.4rem">
                <input type="checkbox" @bind="rule.Enabled" style="width:auto" />
                Enabled
            </label>
        </div>
    </div>

    <div class="ir-card">
        <h2>Event filters</h2>
        <div class="ir-muted" style="margin-bottom:0.75rem">
            Pick the events that should fire this rule. Inotify emits several events per file
            write — the typical order is shown below. For media-server scans the most reliable
            combo is <strong>ClosedWrite</strong> (a writer just finished) plus <strong>Renamed</strong> /
            <strong>MovedTo</strong> (rsync/torrent finalize). <strong>Modified</strong> fires many times per
            write and is usually noisy.
        </div>

        @foreach (var group in eventGroups)
        {
            <div style="margin-top:0.75rem">
                <div style="font-size:0.78rem; text-transform:uppercase; letter-spacing:0.06em; color:#8a97a6; margin-bottom:0.5rem">
                    @group.Title <span style="text-transform:none; letter-spacing:0; color:#6a7989">— @group.Subtitle</span>
                </div>
                <div style="display:grid; gap:0.5rem">
                    @foreach (var ev in group.Events)
                    {
                        var enabled = (rule.EventMask & ev.Type) != 0;
                        <label style="display:grid; grid-template-columns:auto 1fr; gap:0.6rem; align-items:start; padding:0.5rem 0.65rem; border:1px solid #1e2530; border-radius:6px; background:@(enabled ? "#161e2c" : "transparent"); cursor:pointer">
                            <input type="checkbox"
                                   checked="@enabled"
                                   @onchange="e => ToggleFlag(ev.Type, (bool)e.Value!)"
                                   style="width:auto; margin-top:0.15rem" />
                            <div>
                                <div style="font-weight:500">
                                    @ev.Label
                                    @if (ev.Recommended)
                                    {
                                        <span class="ir-badge ok" style="margin-left:0.5rem; font-size:0.7rem">recommended</span>
                                    }
                                </div>
                                <div class="ir-muted" style="font-size:0.82rem; margin-top:0.2rem">@ev.Description</div>
                            </div>
                        </label>
                    }
                </div>
            </div>
        }
    </div>

    <div class="ir-card">
        <h2>Sources</h2>
        @foreach (var src in rule.Sources)
        {
            <div class="ir-form-row" style="margin-bottom:0.5rem">
                <div>
                    <label>Path</label>
                    <div style="display:flex; gap:0.4rem">
                        <input @bind="src.Path" placeholder="/watch/movies" style="flex:1" />
                        <button class="btn btn-secondary btn-sm" type="button" @onclick="() => OpenPickerFor(src)">Browse…</button>
                    </div>
                </div>
                <div>
                    <label>Glob pattern (optional)</label>
                    <input @bind="src.GlobPattern" placeholder="**/*.mkv" />
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.75rem">
                <label style="display:flex;align-items:center;gap:0.4rem">
                    <input type="checkbox" @bind="src.Recursive" style="width:auto" /> Recursive
                </label>
                <button class="btn btn-sm btn-danger" @onclick="() => rule.Sources.Remove(src)">Remove</button>
            </div>
            <hr style="border-color:#1e2530"/>
        }
        <button class="btn btn-secondary" @onclick="AddSource">Add source</button>
    </div>

    <InotifyRelay.Web.Components.Shared.FolderPicker @ref="_picker" OnPicked="ApplyPickedPath" />

    <div class="ir-card">
        <h2>Targets</h2>
        @if (rule.TargetBindings.Count == 0)
        {
            <p class="ir-muted">No targets bound yet.</p>
        }
        else
        {
            <table class="ir-table">
                <thead><tr><th>Target</th><th>Delay (ms)</th><th>Enabled</th><th></th></tr></thead>
                <tbody>
                @foreach (var b in rule.TargetBindings)
                {
                    <tr>
                        <td>@(targets.FirstOrDefault(t => t.Id == b.TargetId)?.Name ?? b.TargetId.ToString())</td>
                        <td><input type="number" @bind="b.DelayMs" style="width:8em" /></td>
                        <td><input type="checkbox" @bind="b.Enabled" style="width:auto" /></td>
                        <td><button class="btn btn-sm btn-danger" @onclick="() => rule.TargetBindings.Remove(b)">Remove</button></td>
                    </tr>
                }
                </tbody>
            </table>
        }

        <div style="display:flex;gap:0.5rem;margin-top:0.75rem;align-items:end">
            <div style="flex:1">
                <label>Add target</label>
                <select @bind="addTargetId" style="width:100%;background:#0a0e13;border:1px solid #1e2530;color:#e6edf3;border-radius:6px;padding:0.5rem">
                    <option value="">(choose)</option>
                    @foreach (var t in targets.Where(t => !rule.TargetBindings.Any(b => b.TargetId == t.Id)))
                    {
                        <option value="@t.Id">@t.Name (@t.ProviderType)</option>
                    }
                </select>
            </div>
            <button class="btn btn-secondary" @onclick="AddBinding" disabled="@string.IsNullOrEmpty(addTargetId)">Bind</button>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    RuleEntity? rule;
    List<TargetEntity> targets = new();
    string addTargetId = "";
    string? saveError;

    InotifyRelay.Web.Components.Shared.FolderPicker? _picker;
    SourceEntity? _pickerTarget;

    void OpenPickerFor(SourceEntity src)
    {
        _pickerTarget = src;
        _picker?.Open(string.IsNullOrEmpty(src.Path) ? null : src.Path);
    }

    void ApplyPickedPath(string path)
    {
        if (_pickerTarget is not null) _pickerTarget.Path = path;
        _pickerTarget = null;
    }

    record EventOption(FileEventType Type, string Label, string Description, bool Recommended = false);
    record EventGroup(string Title, string Subtitle, EventOption[] Events);

    static readonly EventGroup[] eventGroups = new[]
    {
        new EventGroup("File lifecycle", "typical order for a local write",
            new[]
            {
                new EventOption(FileEventType.Created, "Created",
                    "File appears on disk. Usually empty at this point if a writer is creating it — content arrives later."),
                new EventOption(FileEventType.Modified, "Modified",
                    "File content changed. Fires repeatedly during a write (potentially hundreds of times). Noisy — prefer ClosedWrite unless you specifically need write progress."),
                new EventOption(FileEventType.ClosedWrite, "ClosedWrite",
                    "A writer that had the file open for writing has closed it. The most reliable \"file is fully written\" signal for local copies, downloads-in-place, and saves.",
                    Recommended: true),
                new EventOption(FileEventType.Deleted, "Deleted",
                    "File was removed from a watched path."),
            }),
        new EventGroup("Rename / move", "rsync, torrent clients, atomic uploads",
            new[]
            {
                new EventOption(FileEventType.Renamed, "Renamed",
                    "MovedFrom + MovedTo pair within the same source — emitted as one event when both sides arrive within ~200 ms. Recommended for rsync (which writes to a temp file then renames into place) and torrent clients that finalize via rename.",
                    Recommended: true),
                new EventOption(FileEventType.MovedTo, "MovedTo",
                    "File appeared via rename / move from outside the watched tree (or the matching MovedFrom didn't arrive in time)."),
                new EventOption(FileEventType.MovedFrom, "MovedFrom",
                    "File disappeared via rename / move out of the watched tree (standalone half of a rename)."),
            }),
        new EventGroup("Directory", "applies to subdirectories under a recursive source",
            new[]
            {
                new EventOption(FileEventType.DirCreated, "DirCreated",
                    "A new subdirectory appeared. The watcher automatically begins watching it too."),
                new EventOption(FileEventType.DirDeleted, "DirDeleted",
                    "A subdirectory was removed."),
            }),
        new EventGroup("Other", "metadata + health",
            new[]
            {
                new EventOption(FileEventType.Attrib, "Attrib",
                    "Permissions, ownership, or timestamps changed. No content change."),
                new EventOption(FileEventType.Overflow, "Overflow",
                    "The kernel inotify queue overflowed — events were dropped. Emitted as one synthetic event so you can trigger a fresh scan."),
            }),
    };

    protected override async Task OnInitializedAsync()
    {
        rule = await RuleSvc.GetAsync(Id);
        targets = await TargetSvc.ListAsync();
    }

    void ToggleFlag(FileEventType f, bool on)
    {
        if (rule is null) return;
        rule.EventMask = on ? (rule.EventMask | f) : (rule.EventMask & ~f);
    }

    void AddSource()
    {
        rule!.Sources.Add(new SourceEntity { RuleId = rule.Id, Path = "" });
    }

    void AddBinding()
    {
        if (rule is null || !Guid.TryParse(addTargetId, out var tid)) return;
        rule.TargetBindings.Add(new TargetBindingEntity { RuleId = rule.Id, TargetId = tid, Enabled = true });
        addTargetId = "";
    }

    async Task SaveAsync()
    {
        if (rule is null) return;
        saveError = null;
        try
        {
            await RuleSvc.SaveAsync(rule);
            Nav.NavigateTo("/rules");
        }
        catch (InotifyRelay.Web.Services.DuplicateNameException ex)
        {
            saveError = ex.Message;
        }
    }
}
