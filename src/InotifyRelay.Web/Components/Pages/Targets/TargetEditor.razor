@page "/targets/{Id:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Text.Json
@using InotifyRelay.Core.Pipeline
@using InotifyRelay.Core.Providers
@using InotifyRelay.Data.Entities
@inject InotifyRelay.Web.Services.TargetService TargetSvc
@inject NavigationManager Nav

<PageTitle>Edit target — inotify-relay</PageTitle>

@if (target is null)
{
    <p class="ir-muted">Loading…</p>
}
else
{
    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem">
        <h1 style="margin:0">@target.Name <span class="ir-badge" style="vertical-align:middle">@target.ProviderType</span></h1>
        <div>
            <button class="btn btn-secondary" @onclick="TestAsync" disabled="@testing">@(testing ? "Testing…" : "Test")</button>
            <button class="btn btn-primary" @onclick="SaveAsync">Save</button>
            <a class="btn btn-secondary" href="/targets">Back</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(saveError))
    {
        <div class="alert-error" style="margin-top:1rem">@saveError</div>
    }

    @if (testResult is not null)
    {
        <div class="ir-card" style="margin-top:1rem">
            <strong>Test result:</strong>
            <span class="ir-badge @(testResult.Success ? "ok" : "bad")" style="margin-left:0.5rem">@(testResult.Success ? "OK" : "FAIL") @testResult.StatusCode</span>
            <span class="ir-muted" style="margin-left:0.5rem">@testResult.Elapsed.TotalMilliseconds.ToString("F0") ms</span>
            @if (!string.IsNullOrEmpty(testResult.Error))
            {
                <pre style="margin-top:0.5rem;color:#ff8d8d;white-space:pre-wrap">@testResult.Error</pre>
            }
            @if (!string.IsNullOrEmpty(testResult.ResponseSnippet))
            {
                <pre style="margin-top:0.5rem;background:#0a0e13;padding:0.5rem;border-radius:6px;max-height:200px;overflow:auto">@testResult.ResponseSnippet</pre>
            }
        </div>
    }

    <div class="ir-card" style="margin-top:1rem">
        <h2>General</h2>
        <div class="ir-form-grid">
            <div>
                <label>Name</label>
                <input @bind="target.Name" />
            </div>
        </div>
    </div>

    <div class="ir-card">
        <h2>Provider config</h2>
        <p class="ir-muted">JSON shape depends on provider type. The default is pre-filled when the target is created.</p>
        <InotifyRelay.Web.Components.Shared.CodeEditor
            @bind-Value="target.ProviderConfigJson"
            Language="json"
            Height="360" />
    </div>

    <div class="ir-card">
        <h2>Path mappings</h2>
        <p class="ir-muted">
            Rewrite path-derived template variables (<code>{path}</code>, <code>{directory}</code>,
            <code>{sourceRoot}</code>) before they're sent to this target. Longest matching
            prefix wins. Use this when the path inotify-relay sees (e.g.
            <code>/watch/movies/&hellip;</code>) differs from what the target sees (e.g.
            <code>/data/movies/&hellip;</code>). Same idea as Sonarr/Radarr "Remote Path Mappings".
            The raw originals stay available as <code>{source.path}</code> etc.
        </p>
        @if (pathMappings.Count == 0)
        {
            <p class="ir-muted"><em>No mappings configured.</em></p>
        }
        else
        {
            @foreach (var m in pathMappings)
            {
                <div class="ir-form-row" style="margin-bottom:0.5rem;align-items:end">
                    <div>
                        <label>From (path here)</label>
                        <div style="display:flex; gap:0.4rem">
                            <input @bind="m.From" placeholder="/watch/movies" style="flex:1" />
                            <button class="btn btn-secondary btn-sm" type="button" @onclick="() => OpenPickerForFrom(m)">Browse…</button>
                        </div>
                    </div>
                    <div>
                        <label>To (path on target)</label>
                        <div style="display:flex; gap:0.4rem">
                            <input @bind="m.To" placeholder="/data/movies" style="flex:1" />
                            <button class="btn btn-secondary btn-sm" type="button" @onclick="() => OpenPickerForTo(m)">Browse…</button>
                        </div>
                    </div>
                </div>
                <div style="margin-bottom:0.75rem">
                    <button class="btn btn-sm btn-danger" @onclick="() => pathMappings.Remove(m)">Remove</button>
                </div>
            }
        }
        <button class="btn btn-secondary" @onclick="AddMapping">Add mapping</button>
    </div>

    <InotifyRelay.Web.Components.Shared.FolderPicker @ref="_picker" OnPicked="ApplyPickedPath" />

    <div class="ir-card">
        <h2>Coalescing</h2>
        <p class="ir-muted">
            Hold incoming events for this many milliseconds; while events keep arriving the
            timer resets. When it finally goes quiet, descendant paths are dropped if an
            ancestor was also queued (so one Jellyfin scan, not fifty). Set to <code>0</code>
            to fire every event immediately.
        </p>
        <div class="ir-form-grid">
            <div>
                <label>Coalesce window (ms)</label>
                <input type="number" min="0" step="100" @bind="target.CoalesceMs" />
            </div>
        </div>
    </div>

    <div class="ir-card">
        <h2>Retry</h2>
        <div class="ir-form-row">
            <div>
                <label>Max attempts</label>
                <input type="number" min="1" @bind="target.RetryMaxAttempts" />
            </div>
            <div>
                <label>Initial backoff (ms)</label>
                <input type="number" min="0" @bind="target.RetryInitialBackoffMs" />
            </div>
        </div>
        <div class="ir-form-row">
            <div>
                <label>Backoff multiplier</label>
                <input type="number" step="0.1" min="1" @bind="target.RetryBackoffMultiplier" />
            </div>
            <div>
                <label>Max backoff (ms)</label>
                <input type="number" min="0" @bind="target.RetryMaxBackoffMs" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    TargetEntity? target;
    RelayResult? testResult;
    bool testing;
    string? saveError;

    InotifyRelay.Web.Components.Shared.FolderPicker? _picker;
    Action<string>? _pickerCallback;

    void OpenPickerForFrom(MappingRow m)
    {
        _pickerCallback = path => m.From = path;
        _picker?.Open(string.IsNullOrEmpty(m.From) ? null : m.From);
    }

    void OpenPickerForTo(MappingRow m)
    {
        _pickerCallback = path => m.To = path;
        _picker?.Open(string.IsNullOrEmpty(m.To) ? null : m.To);
    }

    void ApplyPickedPath(string path)
    {
        _pickerCallback?.Invoke(path);
        _pickerCallback = null;
    }

    static readonly JsonSerializerOptions JsonOpts = new() { PropertyNameCaseInsensitive = true };

    // Mutable working copy bound to the form. Round-tripped to JSON on save.
    sealed class MappingRow { public string From { get; set; } = ""; public string To { get; set; } = ""; }
    List<MappingRow> pathMappings = new();

    protected override async Task OnInitializedAsync()
    {
        target = await TargetSvc.GetAsync(Id);
        if (target is not null)
        {
            // Format-on-load so the editor always shows pretty JSON, even for rows
            // written before format-on-save existed.
            target.ProviderConfigJson  = InotifyRelay.Web.Services.JsonFormat.Pretty(target.ProviderConfigJson);
            target.DefaultTemplateJson = InotifyRelay.Web.Services.JsonFormat.Pretty(target.DefaultTemplateJson);
            target.PathMappingsJson    = InotifyRelay.Web.Services.JsonFormat.Pretty(target.PathMappingsJson);

            if (!string.IsNullOrWhiteSpace(target.PathMappingsJson))
            {
                try
                {
                    var parsed = JsonSerializer.Deserialize<List<PathMapping>>(target.PathMappingsJson, JsonOpts);
                    if (parsed is not null)
                        pathMappings = parsed.Select(m => new MappingRow { From = m.From, To = m.To }).ToList();
                }
                catch { /* leave empty */ }
            }
        }
    }

    void AddMapping() => pathMappings.Add(new MappingRow());

    async Task SaveAsync()
    {
        if (target is null) return;
        saveError = null;
        var clean = pathMappings
            .Where(m => !string.IsNullOrWhiteSpace(m.From) && !string.IsNullOrWhiteSpace(m.To))
            .Select(m => new PathMapping(m.From.Trim(), m.To.Trim()))
            .ToList();
        target.PathMappingsJson = InotifyRelay.Web.Services.JsonFormat.Serialize(clean);
        try
        {
            await TargetSvc.SaveAsync(target);
            Nav.NavigateTo("/targets");
        }
        catch (InotifyRelay.Web.Services.DuplicateNameException ex)
        {
            saveError = ex.Message;
        }
    }

    async Task TestAsync()
    {
        if (target is null) return;
        testing = true;
        try { testResult = await TargetSvc.TestAsync(target.Id); }
        finally { testing = false; }
    }
}
